service:
  name: "rfp-ingestor"
  port: 8095
  version: "0.1.0"
  debug: false

elasticsearch:
  url: "http://localhost:9200"
  index: "rfp_classified_content"
  bulk_size: 500

feeds:
  # Legacy CanadaBuys URLs — used when `sources` is empty (default).
  new_url: "https://canadabuys.canada.ca/opendata/pub/newTenderNotice-nouvelAvisAppelOffres.csv"
  open_url: "https://canadabuys.canada.ca/opendata/pub/openTenderNotice-ouvertAvisAppelOffres.csv"
  archive_url: "https://canadabuys.canada.ca/opendata/pub/tenderNoticeComplete-avisAppelOffresComplet.csv"

  # Optional multi-source mode: when `sources` is non-empty, only these feeds are polled
  # (parser name must match a registered PortalParser, e.g. CanadaBuys, SEAO).
  # sources:
  #   - name: "CanadaBuys New"
  #     parser: "CanadaBuys"
  #     urls:
  #       - "https://canadabuys.canada.ca/opendata/pub/newTenderNotice-nouvelAvisAppelOffres.csv"
  #     enabled: true
  #   - name: "SEAO Quebec"
  #     parser: "SEAO"
  #     resolver: "seao_ckan"  # Auto-discovers latest weekly JSON from Données Québec CKAN API
  #     urls: []               # Static fallback (ignored when resolver succeeds)
  #     enabled: true

ingestion:
  poll_interval_minutes: 120
  reconcile_cron: "0 9 * * *"

logging:
  level: "info"
  format: "json"
