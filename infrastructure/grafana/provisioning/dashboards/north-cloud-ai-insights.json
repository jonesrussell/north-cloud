    {
      "id": 9,
      "title": "Insights Over Time",
      "description": "Insight count per interval, grouped by severity",
      "type": "timeseries",
      "datasource": { "type": "elasticsearch", "uid": "ai-insights" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "ai-insights" },
          "bucketAggs": [
            { "type": "terms", "field": "severity", "id": "3", "settings": { "order": "desc", "orderBy": "_count", "min_doc_count": "0" } },
            { "type": "date_histogram", "field": "created_at", "id": "2", "settings": { "interval": "auto" } }
          ],
          "metrics": [{ "type": "count", "id": "1" }],
          "query": "*"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "low" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
