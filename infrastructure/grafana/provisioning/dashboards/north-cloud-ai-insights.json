    {
      "id": 17,
      "type": "row",
      "title": "Recent Insights",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }
    },
    {
      "id": 18,
      "title": "Recent Insights Table",
      "description": "Latest AI-generated insights with details",
      "type": "table",
      "datasource": { "type": "elasticsearch", "uid": "ai-insights" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 35 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "ai-insights" },
          "bucketAggs": [],
          "metrics": [
            {
              "type": "raw_data",
              "id": "1",
              "settings": { "size": "50" }
            }
          ],
          "query": "*"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "created_at" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "custom.width", "value": 90 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "high": { "color": "red", "text": "HIGH" }, "medium": { "color": "orange", "text": "MEDIUM" }, "low": { "color": "green", "text": "LOW" } } }
                ]
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "category" },
            "properties": [
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "tokens_used" },
            "properties": [
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "model" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "created_at", "desc": true }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "id": true, "observer_version": true, "_id": true, "_index": true, "_type": true },
            "indexByName": {
              "created_at": 0,
              "severity": 1,
              "category": 2,
              "summary": 3,
              "model": 4,
              "tokens_used": 5,
              "suggested_actions": 6
            }
          }
        }
      ]
    }
