# signal-crawler environment variables
# Copy to .env and fill in values before running

# NorthOps ingest API (required)
NORTHOPS_URL=https://northops.example.com
PIPELINE_API_KEY=your-api-key-here

# Deduplication store (optional, has default)
SIGNAL_DB_PATH=data/seen.db

# Logging (optional, has defaults)
LOG_LEVEL=info
LOG_FORMAT=json

# Config path override (optional)
# CONFIG_PATH=config.yml
