# =================================================================
# SECURITY - NEVER COMMIT THESE FILES
# =================================================================

# Environment Variables
.env
.env.*
!.env.example
.devcontainer/.env
!.devcontainer/.env.example

# MCP Configs (contain SSH credentials)
.mcp.json
.cursor/mcp.json

# Claude settings (contain command history with credentials)
.claude/settings.local.json

# Secrets and Keys
secrets/
*.pem
*.key
*.crt
*.ca
*.p12
*.pfx
*.secret

# =================================================================
# DOCKER AND CONTAINERS
# =================================================================

# Docker Compose override (personal dev settings)
docker-compose.override.yml

# Docker volumes (if stored locally)
.docker-data/
docker-data/

