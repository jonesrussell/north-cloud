FROM golang:1.26.0-alpine

ARG UID=1000
ARG GID=1000

WORKDIR /app

# Install dev tools
RUN apk add --no-cache git bash

# Create non-root user (docker-compose will override UID/GID)
RUN addgroup -g ${GID} appuser && \
    adduser -D -u ${UID} -G appuser appuser

# Writable caches in /tmp (including sumdb for module verification)
RUN mkdir -p /tmp/go-mod-cache \
             /tmp/go-build-cache \
             /tmp/npm-cache \
             /go/pkg/sumdb && \
    chmod -R 1777 /tmp/go-mod-cache \
                  /tmp/go-build-cache \
                  /tmp/npm-cache \
                  /go/pkg/sumdb

# Go cache locations
ENV GOCACHE=/tmp/go-build-cache
ENV GOMODCACHE=/tmp/go-mod-cache
ENV NPM_CONFIG_CACHE=/tmp/npm-cache

EXPOSE 8060 3000

# Default dev command (compose overrides with build-and-run)
CMD ["go", "run", "main.go"]
